# ==============================================================================
# .env.paper.local - Local Paper Trading Configuration
# ==============================================================================
# Purpose: Run local publisher to signals:paper with SOL/USD and ADA/USD
# Created: 2025-11-08
# Usage: Source this file before running publisher
#
# IMPORTANT:
# - This publishes to PRODUCTION stream (signals:paper)
# - Run alongside Fly.io publisher (both write to same stream)
# - Instant rollback: Just kill this process
# - Base pairs (BTC/USD, ETH/USD) come from Fly.io
# - Extra pairs (SOL/USD, ADA/USD) come from this local publisher
# ==============================================================================

# -------------------------
# Publishing Mode
# -------------------------
PUBLISH_MODE=paper

# -------------------------
# Target Stream (Production)
# -------------------------
# Direct override to production stream (signals:paper)
# This takes highest priority in stream selection logic
REDIS_STREAM_NAME=signals:paper

# -------------------------
# Trading Pairs Configuration
# -------------------------
# Base pairs: BTC/USD, ETH/USD (from Fly.io, duplicates will be deduplicated)
# Extra pairs: SOL/USD, ADA/USD (NEW - only from this local publisher)
TRADING_PAIRS=BTC/USD,ETH/USD
EXTRA_PAIRS=SOL/USD,ADA/USD

# -------------------------
# Redis Connection (Production)
# -------------------------
# Redis Cloud TLS connection (shared with Fly.io)
REDIS_URL=rediss://default:Salam78614**$$@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818

# -------------------------
# Redis TLS Configuration
# -------------------------
REDIS_SSL=true
REDIS_SSL_CA_CERT=config/certs/redis_ca.pem

# -------------------------
# Rate Limiting (E1)
# -------------------------
# Enable rate controls to prevent overload
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_SEC=10.0
RATE_LIMIT_PER_PAIR_PER_SEC=3.0
RATE_LIMIT_BURST_MULTIPLIER=2.0
RATE_LIMIT_QUEUE_MAX_SIZE=1000

# -------------------------
# Observability (E2)
# -------------------------
# Metrics OFF by default (enable locally for debugging)
METRICS_ENABLED=false
METRICS_PORT=9090
METRICS_HOST=127.0.0.1

# -------------------------
# Stream Configuration
# -------------------------
# Stream maxlen limits (prevent unbounded growth)
STREAM_MAXLEN_SIGNALS=10000
STREAM_MAXLEN_PNL=5000
STREAM_MAXLEN_HEARTBEAT=1000
STREAM_MAXLEN_METRICS=10000

# -------------------------
# Signal Processing
# -------------------------
MIN_CONFIDENCE=0.7
MAX_SIGNALS_PER_MINUTE=10
MAX_DAILY_SIGNALS=50
SIGNAL_COOLDOWN_SECONDS=300
MAX_CONCURRENT_SIGNALS=3

# -------------------------
# Position Sizing
# -------------------------
BASE_POSITION_SIZE=0.08
MAX_POSITION_SIZE=0.25
SCALP_POSITION_SIZE=0.02

# -------------------------
# Logging
# -------------------------
LOG_LEVEL=INFO

# ==============================================================================
# VERIFICATION CHECKLIST
# ==============================================================================
# Before running:
# ✓ Confirm REDIS_STREAM_NAME=signals:paper (production stream)
# ✓ Confirm EXTRA_PAIRS includes SOL/USD,ADA/USD
# ✓ Verify REDIS_URL matches production
# ✓ Check CA cert exists at config/certs/redis_ca.pem
#
# After starting:
# ✓ Check Redis: redis-cli XLEN signals:paper (should increase)
# ✓ Check API: curl https://crypto-signals-api.fly.dev/signals (4 pairs)
# ✓ Check Site: aipredictedsignals.cloud (SOL/ADA should appear)
#
# Rollback:
# ✗ Kill this process (Ctrl+C)
# ✓ Verify BTC/ETH continue from Fly.io
# ==============================================================================
