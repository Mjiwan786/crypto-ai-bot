# ===============================================
# DOCKER COMPOSE ENVIRONMENT VARIABLES EXAMPLE
# ===============================================
# This file is used by docker-compose.yml
# Copy to .env.staging or .env.prod and configure with your values
# DO NOT commit actual .env files to version control

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment: dev, staging, prod
ENVIRONMENT=staging

# Trading mode: paper, live
MODE=paper

# Timezone for the application (use UTC for production)
TIMEZONE=UTC

# Application name and version
APP_NAME=crypto-ai-bot
APP_VERSION=0.5.0

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Redis Cloud Connection with TLS (for staging/prod)
# Format: rediss://username:password@host:port/database
REDIS_URL=rediss://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT>/0

# Redis TLS Configuration
REDIS_SSL=true
REDIS_TLS_CERT_PATH=/app/certs/redis-ca.crt
REDIS_CONNECTION_TIMEOUT=10
REDIS_SOCKET_TIMEOUT=10

# Alternative Redis configurations for different environments:

# Local Redis (for development)
# REDIS_URL=redis://localhost:6379/0
# REDIS_SSL=false

# Redis Cloud without TLS (if TLS is disabled)
# REDIS_URL=redis://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT>/0
# REDIS_SSL=false

# ===============================================
# KRAKEN API CONFIGURATION
# ===============================================

# Kraken API Base URL
KRAKEN_API_URL=https://api.kraken.com

# Kraken Sandbox (for testing - set to true for staging)
KRAKEN_SANDBOX=true

# API credentials (set these in your actual .env files)
# KRAKEN_API_KEY=your_api_key_here
# KRAKEN_API_SECRET=your_api_secret_here

# API rate limiting
KRAKEN_RATE_LIMIT=2
KRAKEN_RATE_WINDOW=1

# ===============================================
# RISK/SAFETY CONFIGURATION
# ===============================================

# Paper trading settings (true for staging, false for production)
PAPER_TRADING_ENABLED=true

# Live trading confirmation (leave blank for staging)
# For production, set this to "I-accept-the-risk" to enable live trading
LIVE_TRADING_CONFIRMATION=

# Risk management limits
MAX_POSITION_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_CONCURRENT_POSITIONS=2
MAX_ORDER_SIZE_USD=500

# Stop loss and take profit settings
DEFAULT_STOP_LOSS_PCT=0.015
DEFAULT_TAKE_PROFIT_PCT=0.03

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# Log file settings
LOG_FILE_PATH=./logs/crypto_ai_bot.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=10

# Console logging
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ===============================================
# SLO (SERVICE LEVEL OBJECTIVES) CONFIGURATION
# ===============================================

# Health check settings
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SLO targets (in seconds)
MAX_RESPONSE_TIME=2.0
MAX_PROCESSING_TIME=10.0
MIN_UPTIME_PCT=99.5

# ===============================================
# SECURITY SETTINGS
# ===============================================

# SSL/TLS verification
SSL_VERIFY=true
ENABLE_TLS=true

# API key validation
STRICT_API_VALIDATION=true

# ===============================================
# DOCKER COMPOSE SPECIFIC SETTINGS
# ===============================================

# Docker Compose project name
COMPOSE_PROJECT_NAME=crypto-ai-bot

# Docker Compose environment
COMPOSE_ENV=staging

# ===============================================
# REDIS CLOUD CONNECTION DETAILS
# ===============================================
# 
# To connect to Redis Cloud using redis-cli:
# redis-cli -u redis://default:<YOUR_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT> --tls --cacert <path_to_ca_certfile>
#
# Connection details:
# - Host: <YOUR_REDIS_HOST>
# - Port: <YOUR_REDIS_PORT>
# - Username: default
# - Password: <YOUR_REDIS_PASSWORD>
# - Database: 0
# - TLS: Enabled
#
# Note: You'll need to download the CA certificate file for TLS connections
# and place it in the container at the path specified by REDIS_TLS_CERT_PATH

# ===============================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ===============================================

# Staging Environment Overrides
# ENVIRONMENT=staging
# PAPER_TRADING_ENABLED=true
# LIVE_TRADING_CONFIRMATION=
# LOG_LEVEL=INFO
# MAX_POSITION_PCT=0.02
# MAX_DAILY_LOSS_PCT=0.05

# Production Environment Overrides
# ENVIRONMENT=prod
# MODE=live
# PAPER_TRADING_ENABLED=false
# LIVE_TRADING_CONFIRMATION=I-accept-the-risk
# LOG_LEVEL=WARNING
# MAX_POSITION_PCT=0.05
# MAX_DAILY_LOSS_PCT=0.10
# TIMEZONE=UTC

# ===============================================
# USAGE INSTRUCTIONS
# ===============================================
#
# 1. Copy this file to create your environment-specific configuration:
#    cp compose.env.example .env.staging
#    cp compose.env.example .env.prod
#
# 2. Edit the copied files with your actual values:
#    - Set your Kraken API credentials
#    - Adjust risk management settings
#    - Configure Redis connection details
#    - Set appropriate logging levels
#
# 3. For production:
#    - Set MODE=live
#    - Set LIVE_TRADING_CONFIRMATION=I-accept-the-risk
#    - Use production Redis Cloud credentials
#    - Set more conservative risk limits
#    - Use WARNING or ERROR log levels
#
# 4. For staging:
#    - Keep MODE=paper
#    - Leave LIVE_TRADING_CONFIRMATION blank
#    - Use INFO log level for debugging
#    - Use more conservative risk limits than production
#
# 5. Never commit .env.staging or .env.prod files to version control!