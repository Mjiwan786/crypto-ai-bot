# ===============================================
# LOCAL DEVELOPMENT ENVIRONMENT CONFIGURATION
# ===============================================
# This file contains safe defaults for local development
# Copy to .env.local and modify as needed for your local setup

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment: dev, staging, prod
ENVIRONMENT=dev

# Trading mode: paper, live
# Local development should always use paper trading
MODE=paper

# Timezone for the application (use UTC for consistency)
TIMEZONE=UTC

# Application name and version
APP_NAME=crypto-ai-bot
APP_VERSION=0.5.0

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Local Redis connection (no TLS for local development)
REDIS_URL=redis://localhost:6379/0

# Redis connection settings
REDIS_SSL=false
REDIS_TLS_CERT_PATH=
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# Alternative: Use Docker Redis
# REDIS_URL=redis://redis:6379/0

# ===============================================
# KRAKEN API CONFIGURATION
# ===============================================

# Kraken API Base URL
KRAKEN_API_URL=https://api.kraken.com

# Kraken Sandbox (use true for local development)
KRAKEN_SANDBOX=true

# API credentials (set these in your local environment)
# KRAKEN_API_KEY=your_local_api_key_here
# KRAKEN_API_SECRET=your_local_api_secret_here

# API rate limiting (relaxed for local development)
KRAKEN_RATE_LIMIT=1
KRAKEN_RATE_WINDOW=1

# ===============================================
# RISK/SAFETY CONFIGURATION
# ===============================================

# Paper trading settings (always enabled in local dev)
PAPER_TRADING_ENABLED=true

# Live trading confirmation (not required in local dev)
LIVE_TRADING_CONFIRMATION=

# Risk management limits (very conservative for local development)
MAX_POSITION_PCT=0.005
MAX_DAILY_LOSS_PCT=0.01
MAX_CONCURRENT_POSITIONS=1
MAX_ORDER_SIZE_USD=50

# Stop loss and take profit settings
DEFAULT_STOP_LOSS_PCT=0.01
DEFAULT_TAKE_PROFIT_PCT=0.02

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log format: json, text
LOG_FORMAT=text

# Log file settings
LOG_FILE_PATH=./logs/crypto_ai_bot.log
LOG_MAX_SIZE=5m
LOG_MAX_FILES=3

# Console logging
LOG_TO_CONSOLE=true
LOG_TO_FILE=false

# ===============================================
# SLO (SERVICE LEVEL OBJECTIVES) CONFIGURATION
# ===============================================

# Health check settings
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SLO targets (relaxed for local development)
MAX_RESPONSE_TIME=5.0
MAX_PROCESSING_TIME=30.0
MIN_UPTIME_PCT=95.0

# ===============================================
# LOCAL DEVELOPMENT SPECIFIC SETTINGS
# ===============================================

# Enable debug mode
DEBUG=true

# Enable development features
ENABLE_DEV_FEATURES=true
ENABLE_MOCK_DATA=true

# Local database settings
LOCAL_DB_URL=sqlite:///./local_trades.db

# Test data settings
MOCK_DATA_ENABLED=true
MOCK_DATA_INTERVAL=30

# Development tools
ENABLE_PROFILING=true
ENABLE_DEBUG_TOOLBAR=true

# ===============================================
# SECURITY SETTINGS
# ===============================================

# SSL/TLS verification (disabled for local development)
SSL_VERIFY=false
ENABLE_TLS=false

# API key validation (relaxed for local development)
STRICT_API_VALIDATION=false

# ===============================================
# CONDA ENVIRONMENT SETTINGS
# ===============================================

# Conda environment name
CONDA_ENV_NAME=crypto-bot

# Python path (if using conda)
# PYTHON_PATH=/opt/conda/envs/crypto-bot/bin/python

# ===============================================
# DOCKER COMPOSE INTEGRATION
# ===============================================

# Docker Compose project name
COMPOSE_PROJECT_NAME=crypto-ai-bot-local

# Docker Compose environment
COMPOSE_ENV=local

# ===============================================
# USAGE INSTRUCTIONS
# ===============================================
#
# 1. This file is safe to commit to version control
# 2. Copy to .env.local for local development: cp env.local.example .env.local
# 3. Add your actual API keys to .env.local (not committed)
# 4. Adjust risk limits as needed for local testing
# 5. Use DEBUG log level for detailed troubleshooting
# 6. Ensure your conda environment 'crypto-bot' is activated
# 7. Use docker-compose for Redis if not running locally
