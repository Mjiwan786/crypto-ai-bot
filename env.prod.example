# ===============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===============================================
# This file contains safe defaults for production environment
# Copy to .env.prod and modify as needed

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment: dev, staging, prod
ENVIRONMENT=prod

# Trading mode: paper, live
# Production default: live (as specified in requirements)
MODE=live

# Timezone for the application (use UTC for consistency)
TIMEZONE=UTC

# Application name and version
APP_NAME=crypto-ai-bot
APP_VERSION=0.5.0

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Redis Cloud connection with TLS (required for production)
REDIS_URL=rediss://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT>/0

# Redis TLS settings
REDIS_SSL=true
REDIS_TLS_CERT_PATH=/app/certs/redis-ca.crt
REDIS_CONNECTION_TIMEOUT=15
REDIS_SOCKET_TIMEOUT=15

# ===============================================
# KRAKEN API CONFIGURATION
# ===============================================

# Kraken API Base URL
KRAKEN_API_URL=https://api.kraken.com

# Kraken Sandbox (disabled for production)
KRAKEN_SANDBOX=false

# API credentials (set these in your production environment)
# KRAKEN_API_KEY=your_production_api_key_here
# KRAKEN_API_SECRET=your_production_api_secret_here

# API rate limiting
KRAKEN_RATE_LIMIT=3
KRAKEN_RATE_WINDOW=1

# ===============================================
# RISK/SAFETY CONFIGURATION
# ===============================================

# Paper trading settings (disabled for production)
PAPER_TRADING_ENABLED=false

# Live trading confirmation (REQUIRED in production)
# Must be set to "I-accept-the-risk" to enable live trading
LIVE_TRADING_CONFIRMATION=I-accept-the-risk

# Risk management limits (production settings)
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.10
MAX_CONCURRENT_POSITIONS=3
MAX_ORDER_SIZE_USD=1000

# Stop loss and take profit settings
DEFAULT_STOP_LOSS_PCT=0.01
DEFAULT_TAKE_PROFIT_PCT=0.02

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING

# Log format: json, text
LOG_FORMAT=json

# Log file settings
LOG_FILE_PATH=./logs/crypto_ai_bot.log
LOG_MAX_SIZE=100m
LOG_MAX_FILES=20

# Console logging
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ===============================================
# SLO (SERVICE LEVEL OBJECTIVES) CONFIGURATION
# ===============================================

# Health check settings
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SLO targets (in seconds) - strict for production
MAX_RESPONSE_TIME=1.0
MAX_PROCESSING_TIME=5.0
MIN_UPTIME_PCT=99.9

# ===============================================
# PRODUCTION SPECIFIC SETTINGS
# ===============================================

# Enable debug mode (disabled for production)
DEBUG=false

# Enable production features
ENABLE_DEV_FEATURES=false
ENABLE_MOCK_DATA=false

# Production database settings
PROD_DB_URL=postgresql://user:pass@prod-db:5432/crypto_bot

# Test data settings
MOCK_DATA_ENABLED=false
MOCK_DATA_INTERVAL=0

# ===============================================
# SECURITY SETTINGS
# ===============================================

# SSL/TLS verification (enabled for production)
SSL_VERIFY=true
ENABLE_TLS=true

# API key validation (strict for production)
STRICT_API_VALIDATION=true

# ===============================================
# MONITORING & ALERTING
# ===============================================

# Enable monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL=30

# Alert thresholds (strict for production)
ALERT_ERROR_RATE=0.01
ALERT_RESPONSE_TIME=2.0
ALERT_MEMORY_USAGE=0.85

# ===============================================
# PRODUCTION SAFETY FEATURES
# ===============================================

# Circuit breaker settings
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Emergency stop settings
EMERGENCY_STOP_ENABLED=true
EMERGENCY_STOP_FILE_PATH=/app/emergency_stop.flag

# ===============================================
# USAGE INSTRUCTIONS
# ===============================================
#
# 1. This file is safe to commit to version control
# 2. Copy to .env.prod for production: cp env.prod.example .env.prod
# 3. Add your actual API keys to .env.prod (not committed)
# 4. Verify LIVE_TRADING_CONFIRMATION is set correctly
# 5. Use WARNING log level for production monitoring
# 6. Ensure Redis Cloud TLS certificate is available
# 7. Test thoroughly in staging before deploying to production
