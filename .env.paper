# Paper Trading Trial Environment Configuration
# Generated for bar_reaction_5m strategy paper trading

# ============================================================================
# REDIS CLOUD CONNECTION (REQUIRED)
# ============================================================================
REDIS_URL=rediss://default:Salam78614**$$@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_CA_CERT=C:\Users\Maith\OneDrive\Desktop\crypto_ai_bot\config\certs\redis_ca.pem

# ============================================================================
# TRADING CONFIGURATION
# ============================================================================
# PRD-001 Section 7.2: Trading mode configuration
TRADING_MODE=paper
MODE=paper
BOT_MODE=PAPER

# Strategy configuration
STRATEGY=bar_reaction_5m
STRATEGY_CONFIG=config/bar_reaction_5m.yaml

# Trading pairs (comma-separated) - PRD-001 Section 2.3
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD
PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD

# Timeframes (comma-separated)
TIMEFRAMES=5m
TIMEFRAME=5m

# Exchange
EXCHANGE=kraken

# ============================================================================
# CIRCUIT BREAKERS
# ============================================================================
# Maximum spread in basis points (bps)
SPREAD_BPS_MAX=10.0

# Maximum latency in milliseconds
LATENCY_MS_MAX=500.0

# Maximum drawdown before circuit breaker (from PRD)
MAX_DRAWDOWN_PCT=20.0

# Maximum daily loss
MAX_DAILY_LOSS_PCT=3.0

# Maximum trades per day
MAX_DAILY_TRADES=50

# ============================================================================
# METRICS & MONITORING
# ============================================================================
# Prometheus metrics server port
METRICS_PORT=9108

# Metrics server address (0.0.0.0 for all interfaces)
METRICS_ADDR=0.0.0.0

# ============================================================================
# LOGGING
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# EQUITY
# ============================================================================
# Initial equity in USD (for paper trading)
INITIAL_EQUITY_USD=10000.0
CAPITAL=10000.0

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================
# Signal cooldown in seconds (minimum time between signals per pair)
SIGNAL_COOLDOWN_SECONDS=60

# OHLCV window size (number of bars to keep in memory)
OHLCV_WINDOW_SIZE=300

# Minimum bars required before generating signals
MIN_BARS_REQUIRED=100

# Warmup bars for indicators
WARMUP_BARS=50

# ============================================================================
# SAFETY SETTINGS
# ============================================================================
ENABLE_TRADING=false
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
ENVIRONMENT=paper
APP_NAME=crypto-ai-bot-paper
DEBUG=false
VERBOSE_LOGGING=false
