KRAKEN_API_SECRET=C2qvRK0QoJ81i+IZKsUt8+U1rq7mV+cwvZg2SvDzSfEINRdyB6+N5Zq/fIZ/0MXwYVtM0mqEhMRGQsvqpv9djA==        # use SECRET (not PRIVATE_KEY)
