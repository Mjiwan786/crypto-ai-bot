# --------- App ----------
ENVIRONMENT=prod
TIMEZONE=America/Toronto
LOG_LEVEL=WARNING
APP_NAME=crypto-ai-bot
RUN_MODE=prod

# --------- Trading Mode ----------
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=I-accept-the-risk
TRADING_HOURS_ONLY=false

# --------- Redis Cloud (TLS) ----------
REDIS_URL=rediss://default:inwjuBWkh4rAtGnbQkLBuPkHXSmfokn8@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818/0
REDIS_SSL=true
REDIS_POOL_MAX=20
REDIS_SOCKET_TIMEOUT=30
REDIS_CA_CERT=./config/certs/redis_ca.pem

# --- Streams (match your YAML)
SIGNALS_STREAM_PAPER=signals:paper
SIGNALS_STREAM_LIVE=signals:live
KRAKEN_OHLC_PREFIX=kraken:ohlc

# --------- Kraken ----------
