# Redis Cloud Configuration (TLS)
REDIS_URL=rediss://default:Salam78614%2A%2A%24%24@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_SSL=true
REDIS_CA_CERT=C:\Users\Maith\OneDrive\Desktop\crypto_ai_bot\config\certs\redis_ca.pem
REDIS_TLS_CERT_PATH=C:\Users\Maith\OneDrive\Desktop\crypto_ai_bot\config\certs\redis_ca.pem
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=10
REDIS_SOCKET_KEEPALIVE=true

# Stream Configuration
STREAM_MAXLEN=5000
STREAM_SIGNALS_MAXLEN=10000
STREAM_PNL_MAXLEN=10000
STREAM_HEALTH_MAXLEN=5000
STREAM_MAXLEN_SIGNALS=10000
STREAM_MAXLEN_PNL=5000
STREAM_MAXLEN_HEARTBEAT=1000
STREAM_MAXLEN_METRICS=10000

# Environment
ENVIRONMENT=prod

# Kraken API Configuration
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_REST_URL=https://api.kraken.com

# Trading Pairs (matching signals-site frontend)
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD
TIMEFRAMES=15s,1m,5m

# Kraken WebSocket Settings
ENABLE_LATENCY_TRACKING=true
ENABLE_HEALTH_MONITORING=true
METRICS_INTERVAL=15
KRAKEN_WS_STREAM_SHARDING=true

# Circuit Breaker Settings
CIRCUIT_BREAKER_SPREAD_THRESHOLD=0.02
CIRCUIT_BREAKER_LATENCY_THRESHOLD=500
CIRCUIT_BREAKER_CONNECTION_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Latency Tracking
LATENCY_WINDOW_SIZE=100
LATENCY_ALERT_THRESHOLD_MS=200

# Trading Mode
TRADING_MODE=paper
SIGNALS_MODE=paper

# Scalping Configuration
SCALP_ENABLED=true
SCALPING_ENABLED=true
SCALPING_MAX_VOLUME_PER_MIN=10000
SCALPING_MAX_TRADES_PER_MIN=5
SCALPING_MIN_SPREAD_BPS=2

# System Health Monitoring
HEALTH_CHECK_INTERVAL=30
HEARTBEAT_INTERVAL=15
PNL_PUBLISH_INTERVAL=60
METRICS_PUBLISH_INTERVAL=30

# Performance Settings
MAX_CONCURRENT_AGENTS=10
SIGNAL_PROCESSING_TIMEOUT=5
ORDER_EXECUTION_TIMEOUT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/crypto_ai_bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Feature Flags
ENABLE_ML_CONFIDENCE_GATE=true
ENABLE_REGIME_DETECTION=true
ENABLE_MICROSTRUCTURE_ANALYSIS=true
ENABLE_SAFETY_GATES=true
