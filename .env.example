STREAM_SIGNALS_LIVE=signals:live
ACTIVE_SIGNALS_STREAM=signals:paper
STREAM_EVENTS=events:bus
STREAM_ORDERS_REQ=orders:requests
STREAM_ORDERS_CONF=orders:confirmations

# (Optional synonyms for tools that use your naming)
REDIS_STREAM_MD_TRADES=md:trades
