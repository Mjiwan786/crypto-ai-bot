# ========================
# APPLICATION / MODE
# ========================
NODE_ENV=production
ENVIRONMENT=prod
APP_NAME=crypto-ai-bot
LOG_LEVEL=INFO
DEBUG=false
VERBOSE_LOGGING=false

# SAFETY
BOT_MODE=PAPER                # PAPER | LIVE | BACKTEST | STOP
ENABLE_TRADING=false
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=    # set to: I-accept-the-risk (NO quotes) for live

# Optional: default settings file
SETTINGS_FILE=config/settings.yaml

# ========================
# REDIS CLOUD (TLS)
# ========================
# One source of truth:
REDIS_URL=rediss://default:inwjuBWkh4rAtGnbQkLBuPkHXSmfokn8@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_PASSWORD=inwjuBWkh4rAtGnbQkLBuPkHXSmfokn8
REDIS_DB=0

# TLS/verification
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required          # none|optional|required
REDIS_SSL_CHECK_HOSTNAME=true
REDIS_CA_CERT_USE_CERTIFI=true
REDIS_CA_CERT_PATH=config/certs/redis_ca.pem
REDIS_DECODE_RESPONSES=true
REDIS_CLIENT_NAME=crypto-ai-bot

# Pooling / timeouts / retries
REDIS_MAX_CONNECTIONS=30
REDIS_CONNECTION_POOL_SIZE=30
REDIS_SOCKET_TIMEOUT=10
REDIS_SOCKET_CONNECT_TIMEOUT=10
REDIS_HEALTH_CHECK_INTERVAL=15
REDIS_TIMEOUT=10000
REDIS_RETRY_ATTEMPTS=3
REDIS_RETRY_ON_TIMEOUT=true

# Redis host and port (extracted from URL)
REDIS_HOST=redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com
REDIS_PORT=19818
REDIS_USERNAME=default

# Compression & batch
REDIS_STREAM_BATCH_SIZE=50
REDIS_PIPELINE_THRESHOLD=25
REDIS_STREAM_MAX_LEN=10000
REDIS_COMPRESSION_ENABLED=true
REDIS_COMPRESSION_THRESHOLD_KB=2

# Keepalives
REDIS_KEEPALIVE_ENABLED=true
REDIS_KEEPALIVE_IDLE=1
REDIS_KEEPALIVE_INTERVAL=3
REDIS_KEEPALIVE_COUNT=5

# Backoff
RECONNECT_INITIAL_BACKOFF_MS=200
RECONNECT_MAX_BACKOFF_MS=10000
RECONNECT_JITTER_MS=300

# Circuit breakers / monitoring
CIRCUIT_BREAKER_REDIS_ERRORS=5
CIRCUIT_BREAKER_REDIS_WINDOW_SECONDS=60
CIRCUIT_BREAKER_REDIS_TIMEOUT_SECONDS=45
REDIS_METRICS_ENABLED=true
REDIS_LATENCY_MONITORING=true
REDIS_MEMORY_MONITORING=true
REDIS_CONNECTION_MONITORING=true
ALERT_REDIS_LATENCY_MS=100
ALERT_REDIS_MEMORY_MB=200
ALERT_REDIS_CONNECTIONS=12
ALERT_REDIS_ERROR_RATE=0.05

# Startup validations
VALIDATE_REDIS_ON_STARTUP=true
REDIS_STARTUP_TIMEOUT_SECONDS=30
REDIS_HEALTH_CHECK_ON_STARTUP=true
VALIDATE_STREAMS_ON_STARTUP=true
STREAM_WRITE_TEST_ON_STARTUP=true
STREAM_READ_TEST_ON_STARTUP=true

# ---- Stream names (project-preflight expects these exact keys) ----
STREAM_MD_TRADES=md:trades
STREAM_MD_SPREAD=md:spread
STREAM_MD_BOOK=md:orderbook
STREAM_MD_CANDLES=md:candles
