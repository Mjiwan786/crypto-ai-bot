# ===============================================
# DEVELOPMENT ENVIRONMENT CONFIGURATION
# ===============================================
# This file contains safe defaults for local development
# Copy to .env.dev and modify as needed for your local setup

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment: dev, staging, prod
ENVIRONMENT=dev

# Trading mode: paper, live
# Development should always use paper trading
MODE=paper

# Timezone for the application (use UTC for consistency)
TIMEZONE=UTC

# Application name and version
APP_NAME=crypto-ai-bot
APP_VERSION=0.5.0

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Local Redis connection (no TLS for development)
REDIS_URL=redis://localhost:6379/0

# Redis connection settings
REDIS_SSL=false
REDIS_TLS_CERT_PATH=
REDIS_CONNECTION_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# ===============================================
# KRAKEN API CONFIGURATION
# ===============================================

# Kraken API Base URL
KRAKEN_API_URL=https://api.kraken.com

# Kraken Sandbox (use true for development/testing)
KRAKEN_SANDBOX=true

# API credentials (set these in your local environment)
# KRAKEN_API_KEY=your_dev_api_key_here
# KRAKEN_API_SECRET=your_dev_api_secret_here

# API rate limiting
KRAKEN_RATE_LIMIT=1
KRAKEN_RATE_WINDOW=1

# ===============================================
# RISK/SAFETY CONFIGURATION
# ===============================================

# Paper trading settings (always enabled in dev)
PAPER_TRADING_ENABLED=true

# Live trading confirmation (not required in dev)
LIVE_TRADING_CONFIRMATION=

# Risk management limits (conservative for development)
MAX_POSITION_PCT=0.01
MAX_DAILY_LOSS_PCT=0.02
MAX_CONCURRENT_POSITIONS=1
MAX_ORDER_SIZE_USD=100

# Stop loss and take profit settings
DEFAULT_STOP_LOSS_PCT=0.02
DEFAULT_TAKE_PROFIT_PCT=0.04

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log format: json, text
LOG_FORMAT=text

# Log file settings
LOG_FILE_PATH=./logs/crypto_ai_bot.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Console logging
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ===============================================
# SLO (SERVICE LEVEL OBJECTIVES) CONFIGURATION
# ===============================================

# Health check settings
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SLO targets (in seconds)
MAX_RESPONSE_TIME=1.0
MAX_PROCESSING_TIME=5.0
MIN_UPTIME_PCT=99.0

# ===============================================
# DEVELOPMENT SPECIFIC SETTINGS
# ===============================================

# Enable debug mode
DEBUG=true

# Enable development features
ENABLE_DEV_FEATURES=true
ENABLE_MOCK_DATA=true

# Development database settings
DEV_DB_URL=sqlite:///./dev_trades.db

# Test data settings
MOCK_DATA_ENABLED=true
MOCK_DATA_INTERVAL=60

# ===============================================
# SECURITY SETTINGS
# ===============================================

# SSL/TLS verification (disabled for local development)
SSL_VERIFY=false
ENABLE_TLS=false

# API key validation (relaxed for development)
STRICT_API_VALIDATION=false

# ===============================================
# USAGE INSTRUCTIONS
# ===============================================
#
# 1. This file is safe to commit to version control
# 2. Copy to .env.dev for local development: cp env.dev.example .env.dev
# 3. Add your actual API keys to .env.dev (not committed)
# 4. Adjust risk limits as needed for testing
# 5. Use DEBUG log level for detailed troubleshooting
