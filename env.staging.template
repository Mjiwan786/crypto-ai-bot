# ===============================================
# Staging Environment Configuration Template
# ===============================================
# Copy this to .env.staging and configure with your values

# Environment
ENVIRONMENT=staging
TIMEZONE=UTC
LOG_LEVEL=INFO

# Trading Mode Configuration
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=

# Redis Configuration (Redis Cloud with TLS)
REDIS_URL=rediss://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT>/0
REDIS_SSL=true
REDIS_TLS_CERT_PATH=/app/certs/redis-ca.crt

# Kraken API Configuration
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_API_KEY=your_staging_api_key_here
KRAKEN_API_SECRET=your_staging_api_secret_here
KRAKEN_SANDBOX=false

# Health Check & Monitoring
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Performance & Resource Limits
MAX_MEMORY_MB=1024
MAX_CPU_PERCENT=50

# Risk Management (conservative for staging)
MAX_POSITION_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_CONCURRENT_POSITIONS=2

# Logging Configuration
LOG_FORMAT=json
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# Security Settings
SSL_VERIFY=true
ENABLE_TLS=true

# Docker Compose Settings
COMPOSE_PROJECT_NAME=crypto-ai-bot
COMPOSE_ENV=staging