# Paper Trading Environment Configuration (Live Scalper)
# =======================================================
# Safe testing environment for live scalper without real money

# =============================================================================
# MODE CONFIGURATION
# =============================================================================

# LIVE_MODE: false for paper trading
LIVE_MODE=false

# Live trading confirmation (not needed for paper mode)
LIVE_TRADING_CONFIRMATION=

# =============================================================================
# REDIS CLOUD CONNECTION
# =============================================================================

# Redis Cloud URL with TLS (rediss://)
REDIS_URL=rediss://default:Salam78614**$$@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818

# Redis TLS CA Certificate
REDIS_CA_CERT=config/certs/redis_ca.pem

# =============================================================================
# KRAKEN API CREDENTIALS (OPTIONAL FOR PAPER)
# =============================================================================

# Kraken API Key (can use read-only key for paper mode)
KRAKEN_API_KEY=

# Kraken API Secret
KRAKEN_API_SECRET=

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Trading pairs (comma-separated)
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD

# Max trades per minute (rate limiting)
SCALPER_MAX_TRADES_PER_MINUTE=4

# =============================================================================
# MONITORING & ALERTS
# =============================================================================

# Health check port
HEALTH_PORT=8080

# Prometheus metrics port
PROMETHEUS_PORT=9108

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable 5-second bars (experimental)
ENABLE_5S_BARS=false

# Paper trading initial balance
PAPER_INITIAL_BALANCE=10000.0

# =============================================================================
# NOTES
# =============================================================================
# - Paper mode is safe for testing - no real money at risk
# - All safety rails are still enforced for realistic testing
# - Use this to validate configuration before going live
