# Live Trading Environment Configuration
# ========================================
# WARNING: This is for LIVE TRADING with REAL MONEY
# Copy to .env.live and add your credentials

# =============================================================================
# MODE CONFIGURATION
# =============================================================================

# LIVE_MODE: Set to true for live trading
LIVE_MODE=true

# REQUIRED: Live trading confirmation (must match exactly)
LIVE_TRADING_CONFIRMATION="I confirm live trading"

# =============================================================================
# REDIS CLOUD CONNECTION
# =============================================================================

# Redis Cloud URL with TLS (rediss://)
REDIS_URL=rediss://default:YOUR_PASSWORD@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818

# Redis TLS CA Certificate
REDIS_CA_CERT=config/certs/redis_ca.pem

# =============================================================================
# KRAKEN API CREDENTIALS
# =============================================================================

# Kraken API Key (from Kraken account settings)
KRAKEN_API_KEY=your_kraken_api_key_here

# Kraken API Secret (from Kraken account settings)
KRAKEN_API_SECRET=your_kraken_api_secret_here

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Trading pairs (comma-separated)
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD

# Max trades per minute (rate limiting)
SCALPER_MAX_TRADES_PER_MINUTE=4

# =============================================================================
# MONITORING & ALERTS
# =============================================================================

# Health check port
HEALTH_PORT=8080

# Prometheus metrics port
PROMETHEUS_PORT=9108

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable 5-second bars (experimental)
ENABLE_5S_BARS=false

# =============================================================================
# SAFETY NOTES
# =============================================================================
# - Start with PAPER mode first to validate configuration
# - Monitor closely for the first 24 hours in live mode
# - Safety rails are enforced: -6% daily stop, +2.5% target, 75% max heat
# - Keep API keys secure and never commit to version control
