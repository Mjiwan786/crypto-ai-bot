# ==============================================================================
# CRYPTO-AI-BOT — LIVE TRADING ENVIRONMENT (EXAMPLE)
# ==============================================================================
#
# WARNING: Live trading involves REAL MONEY. Review all settings carefully.
# Start with minimum capital ($100) and gradually increase as confidence builds.
#
# Copy this file to .env and fill in your actual credentials.
#
# ==============================================================================

# =============================================================================
# MODE CONFIGURATION (CRITICAL)
# =============================================================================

# Engine mode controls which Redis streams are used:
# - "paper" → publishes to signals:paper, pnl:paper (backtests/marketing)
# - "live"  → publishes to signals:live, pnl:live (real trading)
ENGINE_MODE=live

# REQUIRED: Live trading confirmation - must be EXACTLY this phrase
# The system will REFUSE to execute live trades without this confirmation
LIVE_TRADING_CONFIRMATION=I-accept-the-risk

# Legacy mode flags (for backward compatibility)
TRADING_MODE=live
BOT_MODE=LIVE
ENABLE_TRADING=true
PAPER_TRADING_ENABLED=false

# =============================================================================
# CAPITAL CONFIGURATION (MICRO-CAPITAL MODE)
# =============================================================================

# Starting capital for live trading - used for position sizing calculations
# This value is used to calculate:
#   - Max position size (25% of capital = $25 on $100)
#   - Daily loss limit (5% of capital = $5 on $100)
#   - Risk per trade (2% of capital = $2 on $100)
#
# Recommended: Start with $100-$500 for initial live testing
TRADING_CAPITAL_USD=100.0

# =============================================================================
# REDIS CLOUD CONNECTION
# =============================================================================

# Redis Cloud URL with TLS (rediss://)
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:YOUR_PORT
REDIS_PASSWORD=YOUR_PASSWORD
REDIS_DB=0

# Redis TLS Configuration
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required
REDIS_SSL_CHECK_HOSTNAME=true
REDIS_CA_CERT_PATH=config/certs/redis_ca.pem
REDIS_CLIENT_NAME=crypto-ai-bot-live

# Connection settings
REDIS_MAX_CONNECTIONS=30
REDIS_SOCKET_TIMEOUT=10
REDIS_HEALTH_CHECK_INTERVAL=15

# =============================================================================
# KRAKEN API CREDENTIALS
# =============================================================================

# Get your API keys from https://www.kraken.com/u/security/api
# Use restricted API keys with only the permissions you need:
# - Query Funds (required)
# - Query Orders & Trades (required)
# - Create & Modify Orders (required for live trading)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Trading pairs (comma-separated) - must match canonical pairs
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,LINK/USD

# Timeframes for market data
TIMEFRAMES=15s,1m,5m

# Max trades per minute (rate limiting)
SCALPER_MAX_TRADES_PER_MINUTE=4

# =============================================================================
# RISK GUARD CONFIGURATION (Safe Defaults for $100 Capital)
# =============================================================================
# These are the HARD LIMITS enforced before any order is sent.
# All defaults are conservative and designed for $100 capital safety.

# Master switch - must explicitly enable live trading
# Default: false (requires explicit opt-in)
LIVE_TRADING_ENABLED=false

# Maximum position size in USD
# Default: $25 (25% of $100 capital)
MAX_POSITION_SIZE_USD=25

# Maximum daily loss before trading halts
# Default: $2 (2% of $100 capital - very conservative)
MAX_DAILY_LOSS_USD=2

# Maximum trades per day
# Default: 8 (prevents overtrading)
MAX_TRADES_PER_DAY=8

# Risk per trade as percentage of capital
# Default: 0.5% (very conservative)
RISK_PER_TRADE_PCT=0.5

# Cooldown period after a loss (seconds)
# Default: 300 (5 minutes)
COOLDOWN_SECONDS_AFTER_LOSS=300

# =============================================================================
# EMERGENCY CONTROLS
# =============================================================================

# EMERGENCY_STOP: Set to "true" to immediately halt ALL execution
# This is the master kill switch - blocks all new orders instantly
# Exits/closes are still allowed to protect capital
EMERGENCY_STOP=false

# Legacy emergency halt flags (for backward compatibility)
EMERGENCY_HALT=false
KRAKEN_EMERGENCY_STOP=false

# Webhook for live mode halt notifications (optional)
# Supports Discord, Slack, or any webhook that accepts JSON POST
LIVE_HALT_WEBHOOK_URL=

# =============================================================================
# MONITORING & HEALTH
# =============================================================================

# Health heartbeat configuration
HEARTBEAT_INTERVAL_SEC=30
HEARTBEAT_TTL_SEC=60

# Health check port
HEALTH_PORT=8080

# Prometheus metrics port
PROMETHEUS_PORT=9108

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# TASK SUPERVISION
# =============================================================================
TASK_RESTART_DELAY_SEC=5
TASK_MAX_RESTART_DELAY_SEC=300
TASK_BACKOFF_MULTIPLIER=2

# =============================================================================
# PRE-FLIGHT CHECKLIST (Complete Before Going Live)
# =============================================================================
# [ ] Paper trading has been profitable for at least 10 trades
# [ ] Redis connection is stable and healthy
# [ ] Kraken API credentials are correctly configured and tested
# [ ] TRADING_CAPITAL_USD matches your actual funded Kraken account
# [ ] You have reviewed config/risk_config.yaml (live_mode section)
# [ ] Emergency halt procedures are understood and tested
# [ ] Webhook notifications are configured (recommended)
# [ ] You accept that you may lose your entire trading capital
#
# =============================================================================
# LIVE MODE RISK CONTROLS (see config/risk_config.yaml)
# =============================================================================
# The following limits are enforced when ENGINE_MODE=live:
#
# Position Sizing:
#   - Max position: 25% of capital ($25 on $100)
#   - Min position: $5 (exchange minimum)
#   - Max concurrent positions: 2
#   - Risk per trade: 2% of capital ($2 on $100)
#
# Drawdown Protection:
#   - Daily halt: 5% loss ($5 on $100)
#   - Rolling 4h halt: 3% loss ($3 on $100)
#   - Max consecutive losses: 2 (then halt)
#
# Circuit Breakers:
#   - Max spread: 5 bps (tighter than paper)
#   - Max volatility: 5%
#   - Max latency: 300ms
#   - Min 24h volume: $5M
#
# Emergency Controls:
#   - Auto-halt on any error: enabled
#   - Max total loss: $20 (then permanent halt until reset)
#   - Auto-flatten on halt: enabled
#
# =============================================================================
# TO GO LIVE:
#   1. Copy this file to .env
#   2. Fill in your actual Redis and Kraken credentials
#   3. Set TRADING_CAPITAL_USD to your funded Kraken balance
#   4. Verify LIVE_TRADING_CONFIRMATION=I-accept-the-risk (exact phrase)
#   5. Run: python main_engine.py --mode live
# ==============================================================================
