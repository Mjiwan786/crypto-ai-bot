# Canary Deployment Configuration - D3
# Writes SOL/USD, ADA/USD to PRODUCTION stream (signals:paper)
# Date: 2025-11-08
# Purpose: Test multi-pair expansion in production without Fly.io deployment

# === TARGET: PRODUCTION STREAM ===
PUBLISH_MODE=paper
REDIS_STREAM_NAME=signals:paper  # PRODUCTION (not staging!)

# === TRADING PAIRS ===
TRADING_PAIRS=BTC/USD,ETH/USD  # Base pairs (for logging visibility)
EXTRA_PAIRS=SOL/USD,ADA/USD    # NEW PAIRS (canary deployment)

# === REDIS CLOUD TLS CONNECTION ===
REDIS_URL=rediss://default:Salam78614%2A%2A%24%24@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_SSL=true
REDIS_SSL_CA_CERT=config/certs/redis_ca.pem

# === CANARY-SPECIFIC SETTINGS ===
CANARY_MODE=true  # Marker for logging
ENABLE_5S_BARS=false
SCALPER_MAX_TRADES_PER_MINUTE=4
LATENCY_MS_MAX=100.0
ENABLE_LATENCY_TRACKING=true

# === SAFETY NOTES ===
# - This configuration targets PRODUCTION stream (signals:paper)
# - BTC/ETH signals will come from Fly.io deployment
# - SOL/ADA signals will come from this canary process
# - Rollback: kill this process (Fly.io continues with BTC/ETH)
# - No Fly.io machines touched
# - No code deployment required
