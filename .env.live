# ===============================================
# LIVE TRADING ENVIRONMENT CONFIGURATION
# ===============================================
# ⚠️  WARNING: This configuration is for LIVE TRADING with REAL MONEY
# ⚠️  All safety mechanisms are enforced per PRD-001
# ===============================================

# =============================================================================
# TRADING MODE (REQUIRED)
# =============================================================================
TRADING_MODE=live
MODE=live
BOT_MODE=LIVE

# =============================================================================
# SAFETY SWITCHES (REQUIRED)
# =============================================================================
# MUST be set to true explicitly to enable live trading
ENABLE_TRADING=false

# MUST match exactly: "I_UNDERSTAND_REAL_MONEY"
LIVE_TRADING_CONFIRMATION=

# =============================================================================
# REDIS CLOUD CONNECTION (REQUIRED)
# =============================================================================
REDIS_URL=rediss://default:Salam78614**$$@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_SSL=true
REDIS_SSL_CA_CERT=config/certs/redis_ca.pem
REDIS_CA_CERT=config/certs/redis_ca.pem

# =============================================================================
# KRAKEN API CREDENTIALS (REQUIRED FOR LIVE MODE)
# =============================================================================
# ⚠️  NEVER commit real API keys to version control
# ⚠️  Set these via environment variables or secrets manager
KRAKEN_API_KEY=
KRAKEN_SECRET=

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Trading pairs (per PRD-001: BTC/USD, ETH/USD, SOL/USD, MATIC/USD, LINK/USD)
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD
PAIRS=BTC/USD,ETH/USD,SOL/USD,MATIC/USD,LINK/USD

# Timeframes (per PRD-001)
TIMEFRAMES=15s,1m,5m
TIMEFRAME=5m

# Exchange
EXCHANGE=kraken

# Strategy
STRATEGY=multi_agent
STRATEGY_CONFIG=config/enhanced_scalper_config.yaml

# =============================================================================
# RISK MANAGEMENT (PRD-001 Section 7)
# =============================================================================
# Maximum spread in basis points (0.5% = 50 bps per PRD)
SPREAD_BPS_MAX=50.0

# Maximum latency (500ms P95 target per PRD)
LATENCY_MS_MAX=500.0
ENABLE_LATENCY_TRACKING=true

# Daily drawdown circuit breaker (-5% per PRD)
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=20.0

# Position sizing (per PRD)
BASE_POSITION_SIZE_USD=100
MAX_POSITION_SIZE_USD=2000
MAX_TOTAL_EXPOSURE_USD=10000

# Rate limiting
SCALPER_MAX_TRADES_PER_MINUTE=4
MAX_DAILY_TRADES=100

# =============================================================================
# LOGGING & MONITORING (PRD-001 Section 8)
# =============================================================================
# Log level (INFO for production per PRD)
LOG_LEVEL=INFO
VERBOSE_LOGGING=false

# Health check port (8080 per PRD)
HEALTH_PORT=8080

# Prometheus metrics port (8000 per PRD)
METRICS_PORT=8000
PROMETHEUS_PORT=8000
METRICS_ADDR=0.0.0.0

# =============================================================================
# PERFORMANCE & RELIABILITY (PRD-001 Section 9, 13)
# =============================================================================
# Enable 5-second bars (optional)
ENABLE_5S_BARS=false

# Signal cooldown
SIGNAL_COOLDOWN_SECONDS=60

# OHLCV window
OHLCV_WINDOW_SIZE=300
MIN_BARS_REQUIRED=100
WARMUP_BARS=50

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=production
ENVIRONMENT=live
APP_NAME=crypto-ai-bot-live
DEBUG=false

# =============================================================================
# INITIAL CAPITAL (for tracking only, not used for live trading limits)
# =============================================================================
INITIAL_EQUITY_USD=10000.0
CAPITAL=10000.0

# =============================================================================
# SAFETY CHECKLIST (PRD-001 Compliance)
# =============================================================================
# Before enabling live trading (ENABLE_TRADING=true):
# [ ] All unit tests passing (pytest tests/unit/)
# [ ] All integration tests passing (pytest tests/integration/)
# [ ] All E2E tests passing (pytest tests/e2e/)
# [ ] Test coverage ≥ 80%
# [ ] 24-hour paper trading soak test passed
# [ ] Backtest results: Sharpe ≥ 1.5, Drawdown ≤ -15%, Win Rate ≥ 45%
# [ ] Health checks returning 200 OK
# [ ] Prometheus metrics exposed and validated
# [ ] RUNBOOK.md reviewed and understood
# [ ] On-call engineer designated
# [ ] PagerDuty alerts configured
# [ ] Kraken API keys have correct permissions (trading enabled)
# [ ] Initial capital deposited to Kraken account
# [ ] LIVE_TRADING_CONFIRMATION set to "I_UNDERSTAND_REAL_MONEY"
# [ ] ENABLE_TRADING set to true
#
# ⚠️  RISK DISCLAIMER ⚠️
# Trading cryptocurrency involves substantial risk of loss.
# Past performance is not indicative of future results.
# Only trade with capital you can afford to lose.
# The system operates autonomously once enabled.
# Monitor continuously during first 24-48 hours of live trading.
