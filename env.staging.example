# ===============================================
# STAGING ENVIRONMENT CONFIGURATION
# ===============================================
# This file contains safe defaults for staging environment
# Copy to .env.staging and modify as needed

# ===============================================
# CORE APPLICATION SETTINGS
# ===============================================

# Environment: dev, staging, prod
ENVIRONMENT=staging

# Trading mode: paper, live
# Staging should use paper trading for safety
MODE=paper

# Timezone for the application (use UTC for consistency)
TIMEZONE=UTC

# Application name and version
APP_NAME=crypto-ai-bot
APP_VERSION=0.5.0

# ===============================================
# REDIS CONFIGURATION
# ===============================================

# Redis Cloud connection with TLS (required for staging/prod)
REDIS_URL=rediss://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>:<YOUR_REDIS_PORT>/0

# Redis TLS settings
REDIS_SSL=true
REDIS_TLS_CERT_PATH=/app/certs/redis-ca.crt
REDIS_CONNECTION_TIMEOUT=10
REDIS_SOCKET_TIMEOUT=10

# ===============================================
# KRAKEN API CONFIGURATION
# ===============================================

# Kraken API Base URL
KRAKEN_API_URL=https://api.kraken.com

# Kraken Sandbox (use true for staging)
KRAKEN_SANDBOX=true

# API credentials (set these in your staging environment)
# KRAKEN_API_KEY=your_staging_api_key_here
# KRAKEN_API_SECRET=your_staging_api_secret_here

# API rate limiting
KRAKEN_RATE_LIMIT=2
KRAKEN_RATE_WINDOW=1

# ===============================================
# RISK/SAFETY CONFIGURATION
# ===============================================

# Paper trading settings (enabled for staging safety)
PAPER_TRADING_ENABLED=true

# Live trading confirmation (not required in staging)
LIVE_TRADING_CONFIRMATION=

# Risk management limits (conservative for staging)
MAX_POSITION_PCT=0.02
MAX_DAILY_LOSS_PCT=0.05
MAX_CONCURRENT_POSITIONS=2
MAX_ORDER_SIZE_USD=500

# Stop loss and take profit settings
DEFAULT_STOP_LOSS_PCT=0.015
DEFAULT_TAKE_PROFIT_PCT=0.03

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# Log file settings
LOG_FILE_PATH=./logs/crypto_ai_bot.log
LOG_MAX_SIZE=50m
LOG_MAX_FILES=10

# Console logging
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ===============================================
# SLO (SERVICE LEVEL OBJECTIVES) CONFIGURATION
# ===============================================

# Health check settings
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# Performance monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# SLO targets (in seconds)
MAX_RESPONSE_TIME=2.0
MAX_PROCESSING_TIME=10.0
MIN_UPTIME_PCT=99.5

# ===============================================
# STAGING SPECIFIC SETTINGS
# ===============================================

# Enable debug mode (limited for staging)
DEBUG=false

# Enable staging features
ENABLE_DEV_FEATURES=false
ENABLE_MOCK_DATA=false

# Staging database settings
STAGING_DB_URL=postgresql://user:pass@staging-db:5432/crypto_bot

# Test data settings
MOCK_DATA_ENABLED=false
MOCK_DATA_INTERVAL=0

# ===============================================
# SECURITY SETTINGS
# ===============================================

# SSL/TLS verification (enabled for staging)
SSL_VERIFY=true
ENABLE_TLS=true

# API key validation (strict for staging)
STRICT_API_VALIDATION=true

# ===============================================
# MONITORING & ALERTING
# ===============================================

# Enable monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL=60

# Alert thresholds
ALERT_ERROR_RATE=0.05
ALERT_RESPONSE_TIME=5.0
ALERT_MEMORY_USAGE=0.8

# ===============================================
# USAGE INSTRUCTIONS
# ===============================================
#
# 1. This file is safe to commit to version control
# 2. Copy to .env.staging for staging: cp env.staging.example .env.staging
# 3. Add your actual API keys to .env.staging (not committed)
# 4. Adjust risk limits as needed for staging testing
# 5. Use INFO log level for staging monitoring
# 6. Ensure Redis Cloud TLS certificate is available
