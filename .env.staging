# Staging Environment - For testing new pairs before production
# Stream: signals:paper:staging
# Uses A2 feature flags (PUBLISH_MODE, EXTRA_PAIRS)

# Redis Cloud TLS Connection
REDIS_URL=rediss://default:Salam78614%2A%2A%24%24@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_SSL=true
REDIS_SSL_CA_CERT=config/certs/redis_ca.pem

# === A2 FEATURE FLAGS ===
# PUBLISH_MODE controls stream routing: paper|staging|live
PUBLISH_MODE=staging

# Base trading pairs (defaults to BTC/USD,ETH/USD if not set)
TRADING_PAIRS=BTC/USD,ETH/USD

# Extra pairs (additive, merged with base pairs)
EXTRA_PAIRS=SOL/USD,ADA/USD,AVAX/USD

# Kraken pairs (for data ingestion)
KRAKEN_TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,ADA/USD,AVAX/USD

# Timeframes
TIMEFRAMES=15s,1m,5m

# Performance Settings
ENABLE_5S_BARS=false
SCALPER_MAX_TRADES_PER_MINUTE=4
LATENCY_MS_MAX=100.0
ENABLE_LATENCY_TRACKING=true

# Feature Flags
ENABLE_MULTI_PAIR=true
STAGING_MODE=true

# Legacy compatibility (for backward compat)
TRADING_MODE=paper

# Logging
LOG_LEVEL=INFO
