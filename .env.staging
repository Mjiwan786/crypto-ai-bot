# ===========================================
# CRYPTO AI BOT - STAGING ENVIRONMENT TEMPLATE
# ===========================================
# Copy this file to .env.staging and fill in your values for staging testing

# ===========================================
# SYSTEM CONFIGURATION
# ===========================================
ENVIRONMENT=staging
TIMEZONE=UTC
LOG_LEVEL=INFO

# ===========================================
# TRADING CONFIGURATION (STAGING SAFETY)
# ===========================================
# CRITICAL: Staging must use PAPER mode only
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=
MODE=PAPER

# ===========================================
# KRAKEN API CONFIGURATION
# ===========================================
# Use sandbox/testnet credentials for staging
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_API_KEY=your_staging_kraken_api_key_here
KRAKEN_API_SECRET=your_staging_kraken_api_secret_here

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# For staging, use a separate Redis instance or database
REDIS_URL=redis://localhost:6379/1
# Alternative: Redis Cloud staging instance
# REDIS_URL=redis://username:password@staging-host:port

# ===========================================
# HTTP SERVER CONFIGURATION
# ===========================================
# Health and metrics endpoint for staging
SERVER_PORT=9001

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
# Staging-specific monitoring
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ===========================================
# TRADING PAIRS CONFIGURATION
# ===========================================
# Staging pairs (use major pairs for testing)
SCALPER_PAIRS=BTC/USD,ETH/USD,SOL/USD
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD,ADA/USD

# ===========================================
# RISK MANAGEMENT (STAGING SAFETY)
# ===========================================
# Conservative limits for staging
MAX_POSITION_SIZE=0.01
STOP_LOSS_PERCENTAGE=0.01
TAKE_PROFIT_PERCENTAGE=0.02

# ===========================================
# STAGING-SPECIFIC SETTINGS
# ===========================================
# Enable dry run mode
DRY_RUN=true

# Staging stream names
STREAM_SIGNALS_PAPER=signals:staging
STREAM_EXEC_CONFIRMS=exec:paper:confirms

# Reduced data requirements for staging
TIMEFRAMES=1m,5m
STARTUP_BACKFILL_LIMIT=100

# ===========================================
# AI/ML CONFIGURATION (STAGING)
# ===========================================
# Use lighter models for staging
OPENAI_MODEL=gpt-4o-mini
ML_ENABLED=false
SENTIMENT_ENABLED=false

# ===========================================
# DISCORD CONFIGURATION (STAGING)
# ===========================================
# Use staging Discord webhook
DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=your_staging_discord_webhook_url_here
DISCORD_BOT_TOKEN=your_staging_discord_bot_token_here
DISCORD_BOT_ALERT_CHANNEL_ID=your_staging_channel_id_here

# ===========================================
# VALIDATION SETTINGS
# ===========================================
# Staging validation rules
VALIDATE_ALLOCATIONS=true
FAIL_FAST_ON_POLICY_ERROR=true
STRICT_CONFIG=true

# ===========================================
# PERFORMANCE SETTINGS (STAGING)
# ===========================================
# Reduced performance requirements for staging
HEARTBEAT_INTERVAL=60
HEALTH_CHECK_INTERVAL=30
MAX_LATENCY_MS=1000

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Staging-specific logging
LOG_DIR=logs/staging
LOG_ROTATION=true
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# ===========================================
# SECURITY SETTINGS (STAGING)
# ===========================================
# Staging security settings
SSL_VERIFY=true
RATE_LIMIT_ENABLED=true
CIRCUIT_BREAKER_ENABLED=true

# ===========================================
# TESTING CONFIGURATION
# ===========================================
# Enable test mode features
TEST_MODE=true
MOCK_EXTERNAL_APIS=true
SIMULATE_LATENCY=false
