# Crypto AI Bot - Development Environment Configuration
# Copy to .env.dev for local development
# WARNING: Never commit .env.dev with real credentials

# ==============================================================================
# REDIS CONFIGURATION (TLS Required)
# ==============================================================================
REDIS_URL=rediss://default:<YOUR_PASSWORD>@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818
REDIS_TLS=true
REDIS_CA_CERT=config/certs/redis_ca.pem
REDIS_MAX_CONNECTIONS=10

# ==============================================================================
# KRAKEN API (Sandbox for Development)
# ==============================================================================
KRAKEN_API_KEY=<YOUR_DEV_API_KEY>
KRAKEN_API_SECRET=<YOUR_DEV_API_SECRET>
KRAKEN_SANDBOX=true
KRAKEN_RATE_LIMIT_CALLS=15

# ==============================================================================
# TRADING MODE (PAPER for Development)
# ==============================================================================
TRADING_MODE=PAPER
# LIVE_CONFIRMATION should NEVER be set in dev

# ==============================================================================
# LOGGING
# ==============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ==============================================================================
# STREAMS
# ==============================================================================
STREAM_PREFIX=crypto
SIGNALS_PAPER_STREAM=signals:paper
SIGNALS_LIVE_STREAM=signals:live

# ==============================================================================
# ENVIRONMENT
# ==============================================================================
ENVIRONMENT=development
