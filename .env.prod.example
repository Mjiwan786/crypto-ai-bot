# ===============================================
# Production Environment Configuration Template
# Copy to .env.prod and fill in actual values
# ===============================================

# --------- Application ----------
ENVIRONMENT=prod
TIMEZONE=America/Toronto
LOG_LEVEL=WARNING
APP_NAME=crypto-ai-bot
RUN_MODE=prod

# --------- Trading Mode ----------
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=I-accept-the-risk
TRADING_HOURS_ONLY=false

# --------- Redis Cloud (TLS Required) ----------
# Format: rediss:// (note the double 's' for TLS)
REDIS_URL=rediss://default:<YOUR_PASSWORD>@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818/0
REDIS_SSL=true
REDIS_POOL_MAX=20
REDIS_SOCKET_TIMEOUT=30
REDIS_CA_CERT=./config/certs/redis_ca.pem

# Redis Streams Configuration
SIGNALS_STREAM_PAPER=signals:paper
SIGNALS_STREAM_LIVE=signals:live
KRAKEN_OHLC_PREFIX=kraken:ohlc

# --------- Kraken Exchange ----------
KRAKEN_API_KEY=<YOUR_KRAKEN_API_KEY>
KRAKEN_API_SECRET=<YOUR_KRAKEN_API_SECRET>
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_WS_URL=wss://ws.kraken.com
KRAKEN_WS_PUBLIC=wss://ws.kraken.com
KRAKEN_WS_PRIVATE=wss://ws-auth.kraken.com
KRAKEN_MARKET_TYPE=spot
KRAKEN_SANDBOX=false
KRAKEN_2FA_ENABLED=true
KRAKEN_IP_WHITELIST=true
KRAKEN_MARGIN_ENABLED=false
KRAKEN_EMERGENCY_STOP=

# --------- Scalper Configuration ----------
SCALP_ENABLED=true
SCALP_MIN_VOLUME=0.10
SCALPER_PAIRS=BTC/USD,ETH/USD,SOL/USD
SCALPER_TARGET_BPS=12
SCALPER_STOP_LOSS_BPS=20

# --------- Alerts & Notifications ----------
DISCORD_BOT_TOKEN=<YOUR_DISCORD_BOT_TOKEN>
DISCORD_CHANNEL_ID=<YOUR_DISCORD_CHANNEL_ID>
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>

# --------- Observability ----------
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
HEALTH_API_PORT=9400

# --------- Safety / CI Guards ----------
STRICT_STREAMS=true
ALLOW_CONFIG_WARNINGS=false

# --------- System ----------
TZ=America/Toronto
PYTHONUNBUFFERED=1

# ===============================================
# IMPORTANT SECURITY NOTES:
# ===============================================
# 1. NEVER commit .env.prod with real credentials to git
# 2. Always use rediss:// (TLS) for Redis Cloud in production
# 3. Verify Redis CA cert exists at: config/certs/redis_ca.pem
# 4. Set LIVE_TRADING_CONFIRMATION only when ready for real trading
# 5. Test with PAPER_TRADING_ENABLED=true first
# ===============================================
