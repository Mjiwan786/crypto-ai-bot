# ===========================================
# CRYPTO AI BOT - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# SYSTEM CONFIGURATION
# ===========================================
ENVIRONMENT=prod
TIMEZONE=UTC
LOG_LEVEL=INFO

# ===========================================
# TRADING CONFIGURATION
# ===========================================
# Set to false for live trading (requires confirmation)
PAPER_TRADING_ENABLED=true
LIVE_TRADING_CONFIRMATION=

# ===========================================
# KRAKEN API CONFIGURATION
# ===========================================
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# ===========================================
# REDIS CONFIGURATION
# ===========================================
# For Redis Cloud (recommended for production)
REDIS_URL=redis://username:password@host:port

# For local Redis (use with profile: local)
# REDIS_URL=redis://:crypto123@redis-local:6379

# ===========================================
# HTTP SERVER CONFIGURATION
# ===========================================
# Health and metrics endpoint
SERVER_PORT=9000

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ===========================================
# DATABASE CONFIGURATION (Optional)
# ===========================================
# PostgreSQL for trade history (use with profile: database)
POSTGRES_DB=crypto_bot
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto123

# ===========================================
# TRADING PAIRS CONFIGURATION
# ===========================================
# Comma-separated list of trading pairs
SCALPER_PAIRS=BTC/USD,ETH/USD,SOL/USD

# ===========================================
# RISK MANAGEMENT
# ===========================================
# Maximum position size as percentage of portfolio
MAX_POSITION_SIZE=0.1

# Stop loss percentage
STOP_LOSS_PERCENTAGE=0.02

# Take profit percentage
TAKE_PROFIT_PERCENTAGE=0.05
