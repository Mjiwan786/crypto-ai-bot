# =============================================================================
# Environment Variables - Local Development Example
# =============================================================================
#
# This file provides example environment variables for the crypto-ai-bot system.
# Copy this file to .env.local and fill in your actual values.
#
# IMPORTANT: Never commit .env.local to version control (it's in .gitignore)
#
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js Frontend Configuration (signals-site)
# -----------------------------------------------------------------------------

# API Base URL
# Points to the signals-api FastAPI backend host
# Development: http://localhost:8000
# Staging: https://api-staging.yourdomain.com
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Signals Mode
# Determines which Redis stream to read signals from
# Values: "paper" | "live"
# Paper: signals:paper (safe mode, no real trading)
# Live: signals:live (real trading with actual capital)
NEXT_PUBLIC_SIGNALS_MODE=paper

# Discord Invitation Link
# Holds the Discord server invitation link for community access
# Example: https://discord.gg/yourInviteCode
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/yourInviteCode

# Site Name
# Display name for the application (used in headers, titles, metadata)
SITE_NAME=Crypto AI Bot

# -----------------------------------------------------------------------------
# Redis Cloud Configuration (TLS)
# -----------------------------------------------------------------------------

# Redis Connection URL (with TLS)
# Format: rediss://default:<password>@<host>:<port>/<db>
# Use 'rediss://' prefix for TLS connections
REDIS_URL=rediss://default:YOUR_PASSWORD_HERE@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818/0

# Redis TLS Certificate Path
# Path to the CA certificate file for TLS verification
# Download from Redis Cloud dashboard and place in config/certs/
REDIS_TLS_CERT_PATH=config/certs/ca.crt

# Redis TLS Enabled
# Set to "true" to enable TLS (required for Redis Cloud)
REDIS_TLS=true

# -----------------------------------------------------------------------------
# Trading Mode Configuration
# -----------------------------------------------------------------------------

# Trading Mode
# Values: "PAPER" | "LIVE"
# PAPER: Safe mode, no real trades executed
# LIVE: Real trading with actual capital (requires confirmation)
TRADING_MODE=PAPER

# Live Trading Confirmation
# Required safety flag for LIVE mode
# Must be set to "YES_I_WANT_LIVE_TRADING" to enable live trading
# Leave empty or unset for PAPER mode
LIVE_CONFIRMATION=

# -----------------------------------------------------------------------------
# Exchange API Keys (Kraken)
# -----------------------------------------------------------------------------

# Kraken API Key
# Generate from: https://www.kraken.com/u/security/api
# Permissions required: Query Funds, Query Open Orders, Create & Modify Orders
KRAKEN_API_KEY=your_kraken_api_key_here

# Kraken API Secret
# Keep this secret! Never share or commit to version control
KRAKEN_API_SECRET=your_kraken_api_secret_here

# Kraken Environment
# Values: "sandbox" | "production"
# Sandbox: Use Kraken's test environment (no real money)
# Production: Use Kraken's live trading environment
KRAKEN_ENV=sandbox

# -----------------------------------------------------------------------------
# Supabase Configuration (signals-api backend)
# -----------------------------------------------------------------------------

# Supabase Project URL
# Find in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key
# Public key for client-side authentication
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (Backend Only)
# Private key with admin privileges - use only in backend services
# NEVER expose to frontend clients
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Stripe Configuration (for signals-site subscriptions)
# -----------------------------------------------------------------------------

# Stripe Publishable Key
# Public key for client-side Stripe integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Stripe Secret Key (Backend Only)
# Private key for server-side Stripe operations
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here

# Stripe Webhook Secret
# Used to verify webhook signatures from Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -----------------------------------------------------------------------------
# Logging & Observability
# -----------------------------------------------------------------------------

# Log Level
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Development: DEBUG (verbose)
# Production: WARNING (minimal)
LOG_LEVEL=INFO

# Log Directory
# Path to store application logs
LOG_DIR=logs/

# Enable Prometheus Metrics
# Set to "true" to enable metrics export for monitoring
METRICS_ENABLED=true

# Prometheus Port
# Port for Prometheus metrics endpoint
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Discord Webhook (Alerts)
# -----------------------------------------------------------------------------

# Discord Webhook URL
# Used for sending trading alerts and system notifications
# Create webhook in: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# -----------------------------------------------------------------------------
# System Configuration
# -----------------------------------------------------------------------------

# Environment
# Values: "dev" | "staging" | "prod"
ENVIRONMENT=dev

# Hot Reload Enabled
# Set to "true" to enable configuration hot-reloading
HOT_RELOAD=true

# Max Concurrent Positions
# Maximum number of open positions allowed simultaneously
MAX_CONCURRENT_POSITIONS=3

# Max Position Size (USD)
# Maximum position size in USD per trade
MAX_POSITION_SIZE_USD=1000.00

# =============================================================================
# Usage Instructions
# =============================================================================
#
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
#
# 2. Fill in your actual values (replace placeholders)
#
# 3. Test Redis connection:
#    redis-cli -u redis://default:<password>@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818 \
#      --tls \
#      --cacert config/certs/ca.crt \
#      PING
#    Expected: PONG
#
# 4. Verify environment setup:
#    python scripts/preflight.py --mode dev
#
# 5. Start trading system (paper mode):
#    python scripts/start_trading_system.py --mode paper
#
# =============================================================================
# Security Best Practices
# =============================================================================
#
# ✅ DO:
# - Keep .env.local private (never commit to git)
# - Use different credentials for dev/staging/prod
# - Rotate API keys and secrets regularly
# - Use Kraken sandbox for testing
# - Start with PAPER mode before LIVE
#
# ❌ DON'T:
# - Commit .env.local to version control
# - Share API keys in chat/email/slack
# - Use production keys in development
# - Enable LIVE mode without testing in PAPER first
# - Share SUPABASE_SERVICE_ROLE_KEY publicly
#
