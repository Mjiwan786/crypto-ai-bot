{
  "$defs": {
    "OrderSide": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "OrderSide",
      "type": "string"
    },
    "OrderType": {
      "enum": [
        "market",
        "limit"
      ],
      "title": "OrderType",
      "type": "string"
    },
    "TimeInForce": {
      "enum": [
        "GTC",
        "IOC",
        "FOK"
      ],
      "title": "TimeInForce",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Sized order request after risk/portfolio checks.",
  "properties": {
    "schema_version": {
      "default": "1.0",
      "description": "Schema version for compatibility",
      "title": "Schema Version",
      "type": "string"
    },
    "type": {
      "const": "order.intent",
      "default": "order.intent",
      "title": "Type",
      "type": "string"
    },
    "symbol": {
      "description": "Trading symbol",
      "examples": [
        "BTC/USD"
      ],
      "title": "Symbol",
      "type": "string"
    },
    "side": {
      "$ref": "#/$defs/OrderSide",
      "description": "Trade direction"
    },
    "order_type": {
      "$ref": "#/$defs/OrderType",
      "description": "Order type"
    },
    "price": {
      "anyOf": [
        {
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Price for limit orders (None for market)",
      "title": "Price"
    },
    "size_quote_usd": {
      "description": "Order size in USD",
      "minimum": 1.0,
      "title": "Size Quote Usd",
      "type": "number"
    },
    "reduce_only": {
      "default": false,
      "description": "Reduce-only flag",
      "title": "Reduce Only",
      "type": "boolean"
    },
    "post_only": {
      "default": false,
      "description": "Post-only flag",
      "title": "Post Only",
      "type": "boolean"
    },
    "tif": {
      "$ref": "#/$defs/TimeInForce",
      "default": "GTC",
      "description": "Time in force"
    },
    "metadata": {
      "anyOf": [
        {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              }
            ]
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Order metadata",
      "title": "Metadata"
    },
    "timestamp": {
      "description": "UTC epoch seconds",
      "title": "Timestamp",
      "type": "number"
    }
  },
  "required": [
    "symbol",
    "side",
    "order_type",
    "size_quote_usd",
    "timestamp"
  ],
  "title": "OrderIntent",
  "type": "object"
}