{
  "$defs": {
    "OrderSide": {
      "enum": [
        "buy",
        "sell"
      ],
      "title": "OrderSide",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Trade signal emitted by analysts/strategies.",
  "properties": {
    "schema_version": {
      "default": "1.0",
      "description": "Schema version for compatibility",
      "title": "Schema Version",
      "type": "string"
    },
    "type": {
      "const": "signal",
      "default": "signal",
      "title": "Type",
      "type": "string"
    },
    "id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Event id (UUIDv4)",
      "title": "Id"
    },
    "correlation_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Trace id / flow id",
      "title": "Correlation Id"
    },
    "exchange": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "kraken",
      "description": "Target exchange",
      "title": "Exchange"
    },
    "source": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": "mcp",
      "description": "Producer/source identity",
      "title": "Source"
    },
    "strategy": {
      "description": "Strategy name",
      "examples": [
        "scalp",
        "trend_following"
      ],
      "title": "Strategy",
      "type": "string"
    },
    "symbol": {
      "description": "Trading symbol",
      "examples": [
        "BTC/USD",
        "ETH/USD"
      ],
      "title": "Symbol",
      "type": "string"
    },
    "timeframe": {
      "description": "Timeframe",
      "examples": [
        "15s",
        "1m",
        "3m",
        "5m"
      ],
      "title": "Timeframe",
      "type": "string"
    },
    "side": {
      "$ref": "#/$defs/OrderSide",
      "description": "Trade direction"
    },
    "confidence": {
      "description": "Signal confidence 0..1",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "features": {
      "anyOf": [
        {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              }
            ]
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Numeric feature values",
      "title": "Features"
    },
    "risk": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Risk parameters",
      "examples": [
        {
          "sl_bps": 5,
          "tp_bps": [
            10,
            20
          ],
          "ttl_s": 120
        }
      ],
      "title": "Risk"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional notes",
      "title": "Notes"
    },
    "timestamp": {
      "description": "UTC epoch seconds",
      "title": "Timestamp",
      "type": "number"
    }
  },
  "required": [
    "strategy",
    "symbol",
    "timeframe",
    "side",
    "confidence"
  ],
  "title": "Signal",
  "type": "object"
}