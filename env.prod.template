# Copy this to .env.prod and configure with your values

# Environment
ENVIRONMENT=production
TIMEZONE=UTC
LOG_LEVEL=WARNING

# Trading Mode Configuration
PAPER_TRADING_ENABLED=false
LIVE_TRADING_CONFIRMATION=I CONFIRM LIVE TRADING ENABLED

# Redis Configuration (Redis Cloud with TLS)
REDIS_URL=rediss://default:inwjuBWkh4rAtGnbQkLBuPkHXSmfokn8@redis-19818.c9.us-east-1-4.ec2.redns.redis-cloud.com:19818/0
REDIS_SSL=true
REDIS_TLS_CERT_PATH=/app/certs/redis-ca.crt

# Kraken API Configuration
KRAKEN_API_URL=https://api.kraken.com
KRAKEN_API_KEY=your_production_api_key_here
KRAKEN_API_SECRET=your_production_api_secret_here
KRAKEN_SANDBOX=false

# Health Check & Monitoring
HEALTH_CHECK_PORT=9000
HEALTH_CHECK_INTERVAL=30
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Performance & Resource Limits
MAX_MEMORY_MB=2048
MAX_CPU_PERCENT=80

# Risk Management (production settings)
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.10
MAX_CONCURRENT_POSITIONS=3

# Logging Configuration
LOG_FORMAT=json
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# Security Settings
SSL_VERIFY=true
ENABLE_TLS=true

# Docker Compose Settings
COMPOSE_PROJECT_NAME=crypto-ai-bot
COMPOSE_ENV=production