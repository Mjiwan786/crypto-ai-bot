{
  "dashboard": {
    "title": "Crypto AI Bot - Paper Trading Trial (E2E)",
    "tags": ["crypto-bot", "paper-trading", "monitoring"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Signals Published Total",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(signals_published_total[5m])",
            "legendFormat": "{{agent}} - {{stream}} - {{symbol}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"label": "Signals/sec", "format": "short"},
          {"format": "short"}
        ],
        "tooltip": {"shared": true, "sort": 0, "value_type": "individual"},
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 2,
        "title": "Publish Latency (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(publish_latency_ms_bucket[5m]))",
            "legendFormat": "p95 - {{agent}} - {{stream}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(publish_latency_ms_bucket[5m]))",
            "legendFormat": "p50 - {{agent}} - {{stream}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"label": "Latency (ms)", "format": "ms"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Publish Latency",
          "conditions": [
            {
              "evaluator": {"params": [500], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Publish latency p95 exceeded 500ms threshold",
          "noDataState": "no_data",
          "notifications": []
        },
        "tooltip": {"shared": true, "sort": 0, "value_type": "individual"},
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 3,
        "title": "Circuit Breaker Trips",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(ingestor_disconnects_total[5m])",
            "legendFormat": "Disconnects - {{source}}",
            "refId": "A"
          },
          {
            "expr": "rate(redis_publish_errors_total[5m])",
            "legendFormat": "Redis Errors - {{stream}}",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"label": "Events/sec", "format": "short"},
          {"format": "short"}
        ],
        "alert": {
          "name": "Circuit Breaker Tripped",
          "conditions": [
            {
              "evaluator": {"params": [0.1], "type": "gt"},
              "operator": {"type": "or"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Circuit breaker triggered - check logs",
          "noDataState": "no_data",
          "notifications": []
        },
        "tooltip": {"shared": true, "sort": 0, "value_type": "individual"},
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 4,
        "title": "Bot Heartbeat & Uptime",
        "type": "singlestat",
        "gridPos": {"x": 12, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "bot_uptime_seconds",
            "refId": "A"
          }
        ],
        "format": "s",
        "valueName": "current",
        "valueFontSize": "80%",
        "gaugeShow": false
      },
      {
        "id": 5,
        "title": "Last Heartbeat",
        "type": "singlestat",
        "gridPos": {"x": 18, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "time() - bot_heartbeat_seconds",
            "refId": "A"
          }
        ],
        "format": "s",
        "valueName": "current",
        "valueFontSize": "80%",
        "gaugeShow": false,
        "thresholds": "30,60",
        "colorBackground": true,
        "colors": ["#299c46", "#e5ac0e", "#bf1b00"]
      },
      {
        "id": 6,
        "title": "Stream Lag",
        "type": "graph",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "stream_lag_seconds",
            "legendFormat": "{{stream}} - {{consumer}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"label": "Lag (seconds)", "format": "s"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Stream Lag",
          "conditions": [
            {
              "evaluator": {"params": [5], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "executionErrorState": "alerting",
          "frequency": "1m",
          "handler": 1,
          "message": "Stream lag exceeded 5 seconds",
          "noDataState": "no_data",
          "notifications": []
        },
        "tooltip": {"shared": true, "sort": 0, "value_type": "individual"},
        "legend": {"show": true, "alignAsTable": true, "avg": true, "current": true}
      },
      {
        "id": 7,
        "title": "Signals Published by Symbol",
        "type": "piechart",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "sum by(symbol) (signals_published_total)",
            "legendFormat": "{{symbol}}",
            "refId": "A"
          }
        ],
        "pieType": "donut",
        "legend": {"show": true, "values": true, "percentage": true}
      },
      {
        "id": 8,
        "title": "Total Signals Published (24h)",
        "type": "singlestat",
        "gridPos": {"x": 12, "y": 20, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "sum(increase(signals_published_total[24h]))",
            "refId": "A"
          }
        ],
        "format": "none",
        "valueName": "current",
        "valueFontSize": "80%",
        "gaugeShow": false,
        "sparkline": {"show": true, "full": false, "lineColor": "rgb(31, 120, 193)"}
      },
      {
        "id": 9,
        "title": "Avg Publish Latency (24h)",
        "type": "singlestat",
        "gridPos": {"x": 18, "y": 20, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "avg(rate(publish_latency_ms_bucket[24h]))",
            "refId": "A"
          }
        ],
        "format": "ms",
        "valueName": "current",
        "valueFontSize": "80%",
        "gaugeShow": false,
        "thresholds": "200,500",
        "colorBackground": true,
        "colors": ["#299c46", "#e5ac0e", "#bf1b00"]
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": [
        {
          "datasource": "Prometheus",
          "enable": true,
          "expr": "ALERTS{alertstate=\"firing\"}",
          "iconColor": "rgba(255, 96, 96, 1)",
          "name": "Alerts",
          "step": "60s",
          "tagKeys": "alertname",
          "textFormat": "{{alertname}}",
          "titleFormat": "Alert"
        }
      ]
    },
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    }
  }
}
